# ─────────────────────────────────────────────────────
# WC2026 Trading Terminal — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────

# REQUIRED — Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# FOOTBALL DATA — football-data.org (free)
# Sign up at: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your_key_here

# ODDS — The Odds API (free tier: 500 req/month)
# Sign up at: https://the-odds-api.com
ODDS_API_KEY=your_key_here

# NEWS — NewsAPI (free tier: 100 req/day)
# Sign up at: https://newsapi.org/register
NEWS_API_KEY=your_key_here

# DATABASE — Supabase (free, optional — works without it)
# Sign up at: https://supabase.com
# Get URL + anon key from: Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# PORT (Railway sets this automatically)
PORT=8000
